# Обязательно: токен бота от @BotFather
BOT_TOKEN=123456:ABCDEF

# Рекомендуется: API для обхода блокировок (свой прокси не нужен). Порядок: ScraperAPI → ZenRows → ScrapingBee
# ScraperAPI: https://www.scraperapi.com — 1000 бесплатных запросов/мес, используется первым
SCRAPERAPI_API_KEY=
# ZenRows: https://www.zenrows.com — тариф после бесплатного лимита
ZENROWS_API_KEY=YOUR_API_KEY_HERE
# ScrapingBee: https://www.scrapingbee.com — альтернатива
SCRAPINGBEE_API_KEY=YOUR_SCRAPINGBEE_KEY_HERE

# Прокси для Selenium (только если не используешь ZenRows/ScrapingBee). Примеры:
#   AVITO_PROXY=http://host:port
#   AVITO_PROXY=http://user:pass@host:port
#   AVITO_PROXY=host:port:user:pass   или  host:port@user:pass
# AVITO_PROXY=mobpool.proxy.market:10000@USER:PASS

# Интервал автозапуска парсера (минуты)
PARSER_INTERVAL_MINUTES=5

# Telegram user_id администраторов (через запятую) — для /admin, /grant, /users, /stats
# ADMIN_USER_IDS=123456789,987654321

# API и Mini App (опционально)
# API_PORT=8080
# WEBAPP_URL=https://your-domain.com — URL для кнопки «Открыть приложение» (должен быть HTTPS)
